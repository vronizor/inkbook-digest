<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom"
      xmlns:dc="http://purl.org/dc/terms/"
      xmlns:opds="http://opds-spec.org/2010/catalog">
  <id>{{ feed_id }}</id>
  <title>{{ feed_title }}</title>
  <updated>{{ updated }}</updated>
  <author><name>inkbook-digest</name></author>
  <link rel="self" href="{{ self_url }}" type="application/atom+xml;profile=opds-catalog;kind=acquisition"/>
  <link rel="start" href="{{ root_url }}" type="application/atom+xml;profile=opds-catalog;kind=navigation"/>
  <link rel="up" href="{{ root_url }}" type="application/atom+xml;profile=opds-catalog;kind=navigation"/>
  {% for e in entries %}
  <entry>
    <id>{{ e.id }}</id>
    <title>{{ e.title }}</title>
    <author><name>{{ e.author }}</name></author>
    <updated>{{ e.updated }}</updated>
    <published>{{ e.published }}</published>
    {% if e.summary %}<summary>{{ e.summary }}</summary>{% endif %}
    {% if e.language %}<dc:language>{{ e.language }}</dc:language>{% endif %}
    <link rel="http://opds-spec.org/image" type="image/jpeg" href="{{ e.cover_url }}"/>
    <link rel="http://opds-spec.org/image/thumbnail" type="image/jpeg" href="{{ e.cover_url }}"/>
    <link rel="http://opds-spec.org/acquisition" type="{{ e.media_type }}" href="{{ e.acquisition_url }}"/>
  </entry>
  {% endfor %}
</feed>
